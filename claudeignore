# =============================================================================
# .claudeignore — Proyecto entregas_b2b (Flutter multi-plataforma)
# =============================================================================
# Le dice a Claude Code qué archivos NO debe leer ni indexar.
# Funciona igual que .gitignore pero solo para Claude Code.
# Optimizado para máximo ahorro de tokens.
# =============================================================================


# =============================================================================
# 1. FLUTTER / DART — Archivos generados y caches
# =============================================================================

build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock


# =============================================================================
# 2. CÓDIGO GENERADO POR build_runner
# =============================================================================
# IMPORTANTE: Estos archivos son necesarios para compilar pero NO se editan
# manualmente. Claude debe modificar el archivo fuente y luego ejecutar
# `dart run build_runner build --delete-conflicting-outputs`.
# Filosofía: ahorro máximo de tokens. Si Claude necesita verificar una API
# generada, diagnosticar con `flutter analyze`.

**/*.g.dart
**/*.freezed.dart
**/*.config.dart
**/*.gen.dart
**/*.mocks.dart
**/*.gr.dart
**/*.chopper.dart


# =============================================================================
# 3. ANDROID — Builds, caches y archivos nativos auto-generados
# =============================================================================

android/.gradle/
android/build/
android/app/build/
android/app/release/
android/app/debug/
android/app/profile/
android/captures/
android/.idea/
android/local.properties
android/gradle/
android/gradlew
android/gradlew.bat
**/android/**/gradle-wrapper.jar


# =============================================================================
# 4. iOS — Pods, caches, configuración auto-generada y user-specific
# =============================================================================

ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/App.framework/
ios/Flutter/ephemeral/
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/
ios/build/
ios/DerivedData/
**/*.mode1v3
**/*.mode2v3
**/*.perspectivev3
**/*.pbxuser
**/*.xcuserstate


# =============================================================================
# 5. WEB — Solo lo auto-generado (NO ignorar lib/main.dart ni código fuente)
